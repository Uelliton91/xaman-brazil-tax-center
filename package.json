{
  "name": "xapp",
  "version": "1.0.0",
  "description": "Xaman Brazil Tax Center MVP",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "db:init": "prisma db execute --url \"file:./prisma/dev.db\" --file prisma/init.sql",
    "db:regen-sql": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/init.sql",
    "db:push": "prisma db push",
    "dev": "next dev --webpack",
    "lint": "eslint . --max-warnings=0",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.cjs",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@tanstack/react-query": "^5.90.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "^16.2.0",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.19.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@rollup/rollup-win32-x64-msvc": "^4.59.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.0",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.0",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.6",
    "rollup": "npm:@rollup/wasm-node@^4.59.0",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
